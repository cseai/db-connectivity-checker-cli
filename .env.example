# =============================================================================
# Database connection checker — environment template
# =============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. Copy this file to ".env" in the same directory as main.py:
#      cp .env.example .env
# 2. Edit ".env" and replace the placeholder values with your real settings.
# 3. Keep ".env" private: add it to .gitignore and never commit passwords.
#
# The CLI loads ".env" automatically (via python-dotenv). You can also export
# these variables in your shell instead of using a file, if you prefer.
#
# =============================================================================

# -----------------------------------------------------------------------------
# DEBUG — optional
# -----------------------------------------------------------------------------
# WHAT: When set to true, the CLI prints the full Python traceback if something
#       fails (useful for troubleshooting driver or network issues).
# HOW:  Use "true", "1", or "yes" (case-insensitive). Leave unset or "false" for
#       short, user-friendly error messages only.
# EXAMPLE:
DEBUG=false

# -----------------------------------------------------------------------------
# DB_HOST — required
# -----------------------------------------------------------------------------
# WHAT: Hostname or IP address of the database server you want to reach.
# HOW:  Use the value your DBA or cloud console gives you (e.g. a VM IP,
#       RDS/Azure hostname, or "localhost" only if the DB runs on this machine).
# EXAMPLE:
DB_HOST=192.168.1.10

# -----------------------------------------------------------------------------
# DB_PORT — optional (defaults apply per database type if empty)
# -----------------------------------------------------------------------------
# WHAT: TCP port the database listens on.
# HOW:  Match your server configuration. Typical defaults if you omit this:
#       PostgreSQL → 5432
#       MySQL      → 3306
#       MSSQL      → 1433
# EXAMPLE (PostgreSQL):
DB_PORT=5432

# -----------------------------------------------------------------------------
# DB_USER — required
# -----------------------------------------------------------------------------
# WHAT: Database login name (not your OS user).
# HOW:  Use the SQL user allowed to connect from your network (often created on
#       the server with CREATE USER / GRANT).
# EXAMPLE:
DB_USER=myapp_user

# -----------------------------------------------------------------------------
# DB_PASSWORD — optional but usually required
# -----------------------------------------------------------------------------
# WHAT: Password for DB_USER.
# HOW:  Set to the password for that SQL account. If your server uses trust /
#       IAM / integrated auth only, you may leave this empty where supported.
#       Quote the value if it contains special characters (some shells need this).
# EXAMPLE:
DB_PASSWORD=change_me

# -----------------------------------------------------------------------------
# DB_NAME — required
# -----------------------------------------------------------------------------
# WHAT: Name of the database (schema/catalog) to connect to after login.
# HOW:  Use an existing database on the server (CREATE DATABASE ...). The tool
#       connects to this database to run the test query (SELECT 1).
# EXAMPLE:
DB_NAME=test_db

# -----------------------------------------------------------------------------
# MSSQL_ODBC_DRIVER — only for --db_type=mssql (optional)
# -----------------------------------------------------------------------------
# WHAT: Exact name of the ODBC driver as registered on THIS computer (not the
#       remote server). pyodbc loads that driver library locally.
# HOW:  Run:  odbcinst -q -d
#       If you get "odbcinst: command not found", install the ODBC tools first
#       (Debian/Ubuntu: sudo apt install unixodbc).
#       Pick one line from the output (e.g. "ODBC Driver 17 for SQL Server" or
#       "ODBC Driver 18 for SQL Server") and set it here. If you omit this, the
#       tool falls back to "ODBC Driver 17 for SQL Server", which must exist
#       on your system or you will get "Can't open lib ... file not found".
# EXAMPLE:
# MSSQL_ODBC_DRIVER=ODBC Driver 17 for SQL Server
